    "nuxt": "^4.0.0",
    "pocketbase": "^0.22.0"
  },
  "devDependencies": {
    "@pinia/nuxt": "^0.5.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.0.0"
  }
}
